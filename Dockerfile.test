# Dockerfile.test — read-only, network-isolated test runner
#
# Usage:
#   docker build -f Dockerfile.test -t test-runner .
#   docker run --rm --network none -v $(pwd):/project:ro test-runner
#
# Requirements:
#   - The project root MUST be bind-mounted at /project:ro at runtime.
#     Nothing is COPYed into the image; all source is supplied via the mount.
#   - The container runs as UID 1000 (user: tester) for least-privilege execution.
#   - The container runs with --network none: no network access at runtime.
#   - stdout/stderr carries structured test output (PASS/FAIL lines, JSON, etc.)
#     that is parsed by the tester MCP service.

FROM python:3.12-slim

# Install system dependencies (network is available only during build)
RUN apt-get update && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        tar \
    && rm -rf /var/lib/apt/lists/*

# Install Go from the official tarball (network is available only during build)
ARG GO_VERSION=1.24.1
RUN curl -fsSL "https://dl.google.com/go/go${GO_VERSION}.linux-amd64.tar.gz" \
    | tar -C /usr/local -xz \
    && ln -s /usr/local/go/bin/go /usr/local/bin/go \
    && ln -s /usr/local/go/bin/gofmt /usr/local/bin/gofmt

# Remove curl so it cannot be used at runtime even if network were restored
RUN apt-get purge -y curl && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*

# Pre-download the Go standard library cache so `go test` works offline
RUN GOPATH=/home/tester/go GOMODCACHE=/home/tester/go/pkg/mod go env \
    && chown -R 1000:1000 /home/tester/go || true

# Create non-root user with UID 1000
RUN useradd -u 1000 -m tester

# Set Go env vars for offline operation
ENV GOFLAGS="-mod=vendor"
ENV GONOSUMCHECK=*
ENV GONOSUMDB=*
ENV GOPROXY=off
ENV GOPATH=/home/tester/go

# The project root is supplied at runtime via a read-only bind mount at /project.
WORKDIR /project

USER tester

CMD ["bash", "/project/test.sh"]